rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if user is the document owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Products - anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Categories - anyone can read, only admin can write
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Users - users can read/update their own doc (but NOT change role), admin can do anything
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders - users can read/create their own, admin can read/update all
    match /orders/{orderId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.items is list;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Settings
    // Public config (store info, shipping, notifications, payment method list)
    // is safe to read by anyone. All other settings docs contain secrets
    // (payment provider keys, SMTP password, service-account keys) and must
    // NOT be exposed to the public.
    //
    // Note: writes are handled server-side by the Admin SDK (Cloud Functions),
    // which bypasses these rules. Admin read is kept so the dashboard settings
    // pages can display saved values.
    // Public store config docs are world-readable: the legacy shared "store"
    // doc plus per-store docs "store__<id>" (each storefront deployment scopes
    // its settings by VITE_STORE_ID). Every other settings doc (email, tabby,
    // tamara, cjDropshipping, googleMerchant, ...) holds secrets and is
    // admin-only read. All writes are admin-only.
    match /settings/{settingId} {
      allow read: if settingId == 'store'
        || settingId.matches('store__.*')
        || isAdmin();
      allow write: if isAdmin();
    }

    // Contact Messages - anyone can create, only admin can read/update/delete
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Deny all other documents by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
