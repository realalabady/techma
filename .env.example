VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Store identity — unique id per storefront. Scopes this store's settings to
# its own Firestore document (settings/store__<id>) so multiple stores on the
# same Firebase project keep independent store info / shipping / notifications
# / payment config. Leave empty for a single-store deployment (uses the shared
# legacy "store" doc). Products and categories remain shared regardless.
VITE_STORE_ID=

# Store display name — overrides the store name from Firestore settings.
VITE_STORE_NAME=

# PayPal Configuration
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id
